{
  "name": "astrows",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint ./src --fix",
    "lint:check": "eslint ./src",
    "prepare": "husky",
    "format": "prettier --write ./src --log-level silent",
    "format:check": "prettier --check ./src --log-level silent",
    "prose-install": "node scripts/prose-install.mjs",
    "prose": "node scripts/prose-check.mjs",
    "translate": "node scripts/translate.mjs"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.39.2",
    "astro": "^6.2.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "astro-eslint-parser": "^1.4.0",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript-eslint": "^8.59.3"
  },
  "lint-staged": {
    "*.{ts,tsx,astro}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{md,mdx,css,scss}": [
      "prettier --write"
    ],
    "!package.json": []
  }
}
