# LLM Configuration für Markdown-Übersetzung
# Beispiele:
# - OpenAI: https://api.openai.com/v1, Model: gpt-4-turbo oder gpt-3.5-turbo
# - Ollama lokal: http://localhost:11434/v1, Model: llama2, mistral, etc.
# - LM Studio lokal: http://localhost:1234/v1, Model: (lokal konfiguriert)
# - Groq API: https://api.groq.com/openai/v1, Model: mixtral-8x7b-32768, etc.

# OpenAI-kompatible API URL (mit /v1 suffix)
LLM_API_URL=http://localhost:11434/v1

# API-Schlüssel (für lokale Systeme wie Ollama kann dummy-key verwendet werden)
LLM_API_KEY=dummy-key

# Model-Name
LLM_MODEL=mistral

# Zielsprache für Übersetzung (z.B. de, fr, es, ja)
TARGET_LANG=de
